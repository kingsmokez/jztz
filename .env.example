# 服务配置
APP_PORT=5000
APP_HOST=0.0.0.0
APP_DEBUG=false
APP_SECRET_KEY=your-secret-key-here

# 数据接口
SMARTBOX_TOKEN=your-smartbox-token-here
EM_UT_TOKEN=your-eastmoney-ut-token-here
DATA_TIMEOUT=10
CALIBRATE_THREADS=30
TECH_THREADS=15

# 安全
RATE_LIMIT=60/minute
RATE_LIMIT_API=30/minute
RATE_LIMIT_EXPENSIVE=5/minute
API_KEY=your-api-key-here

# 通知
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# AI (可选)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEXTER_MODEL=deepseek-chat
